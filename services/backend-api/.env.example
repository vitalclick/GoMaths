# Generate strong secrets for production via: openssl rand -base64 64
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# AI services URLs (defaults match running locally with uvicorn).
TUTOR_SERVICE_URL=http://localhost:8001
SOLVER_SERVICE_URL=http://localhost:8002
VALIDATION_SERVICE_URL=http://localhost:8003

# Backend listens on PORT.
PORT=4000

# PostgreSQL connection string. When set, Prisma takes over the
# Conversation / User / Session / Progress / PushToken stores. When unset,
# services fall back to in-memory implementations.
# DATABASE_URL=postgresql://gomaths:devpass@localhost:5432/gomaths?schema=public

# Redis URL for the rate-limiter. When unset the limiter falls back to
# per-pod in-process counters (fine for local dev; production must set
# this so the quota is shared across the deployment).
# REDIS_URL=redis://localhost:6379

# Optional override for filesystem curriculum source.
# CURRICULUM_ROOT=/absolute/path/to/curriculum-data
