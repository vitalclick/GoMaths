{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^generate"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "inputs": ["../../services/backend-api/openapi.yaml"],
      "outputs": ["src/generated.ts"]
    },
    "lint": {
      "dependsOn": ["^build", "^generate"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^generate"]
    },
    "test": {
      "dependsOn": ["^build", "^generate"],
      "outputs": ["coverage/**"]
    }
  }
}
