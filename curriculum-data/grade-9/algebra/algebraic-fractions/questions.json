      "id": "g9.alg.algebraic-fractions.q001",
      "difficulty": "easy",
      "stem": "(2*x + 4)/2",
      "answer": "x + 2",
      "answerLatex": "x + 2",
      "solutionSteps": [
        "Factorise the numerator: 2x + 4 = 2(x + 2).",
        "Cancel the common factor 2 with the denominator.",
        "Left with x + 2."
      ],
      "commonMistakes": [
        "Cancelling only the 4 and not the 2x",
        "Writing x + 4 by dividing only one term"
      ],
      "tags": ["common-factor"]
    },
