# Production env file for the VPS docker compose deployment.
#
# Copy to .env.production at the repo root and fill in every value:
#   cp infrastructure/vps/.env.production.example .env.production
#
# Then start the stack:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# .env.production is gitignored — never commit it.

# =============================================================================
# Domain + TLS
# =============================================================================
# Domain + TLS are configured in the shared Caddy project — see
# infrastructure/vps/caddy/Caddyfile and infrastructure/vps/caddy/.env.
# This file owns no public-facing config.

# =============================================================================
# Database (local postgres container)
# =============================================================================
POSTGRES_USER=gomaths
POSTGRES_DB=gomaths
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=CHANGE_ME

# =============================================================================
# Redis (local redis container)
# =============================================================================
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 32
REDIS_PASSWORD=CHANGE_ME

# =============================================================================
# Backend signing secrets
# =============================================================================
# Generate each: openssl rand -base64 64 | tr -d '\n'
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
PARENTAL_CONSENT_INVITE_SECRET=CHANGE_ME
PARENTAL_CONSENT_RECEIPT_SECRET=CHANGE_ME

# =============================================================================
# Email (Resend) — required for parental consent flow
# =============================================================================
# https://resend.com → API Keys
RESEND_API_KEY=re_...
# Domain part MUST be verified in Resend (DKIM + SPF records added).
EMAIL_FROM=GoMaths <consent@example.com>
# URL students follow from consent emails — points at the student web SPA.
PUBLIC_APP_URL=https://app.example.com

# =============================================================================
# Sentry (optional — leave blank to disable)
# =============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# =============================================================================
# Tutor service
# =============================================================================
# Leave TUTOR_PROVIDER unset to auto-detect by which key is present:
#   1. OPENAI_API_KEY    -> OpenAI provider
#   2. ANTHROPIC_API_KEY -> Anthropic provider
#   3. neither           -> mock provider (canned replies, no LLM cost)
# To force a specific provider, set TUTOR_PROVIDER=openai | anthropic | mock.
TUTOR_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model override. Defaults: gpt-4o-mini (OpenAI), claude-haiku-4-5 (Anthropic).
TUTOR_MODEL=

# =============================================================================
# Solver service (optional — unset = mock OCR provider)
# =============================================================================
SOLVER_OCR_PROVIDER=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
