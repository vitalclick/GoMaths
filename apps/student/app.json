{
  "expo": {
    "name": "GoMaths",
    "slug": "gomaths-v2-student",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gomaths-v2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E8A3E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gomaths.mathai",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.gomaths.mathai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E8A3E"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", ["../../scripts/withKotlinVersion", {}]],
    "experiments": {
      "typedRoutes": true
    }
  }
}
