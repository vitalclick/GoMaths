{
  "expo": {
    "name": "GoMaths",
    "slug": "gomaths-v2-student",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "gomaths-v2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gomaths.mathai"
    },
    "android": {
      "package": "com.gomaths.mathai",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
