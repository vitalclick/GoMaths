{
  "expo": {
    "name": "GoMaths",
    "slug": "gomaths-v2-student",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gomaths-v2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E8A3E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gomaths.mathai",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gomaths.mathai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E8A3E"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "GoMaths needs access to your photos so you can pick a maths problem to solve.",
          "cameraPermission": "GoMaths needs camera access so you can snap a photo of a maths problem to solve."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
